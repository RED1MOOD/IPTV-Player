<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Outer Glow Bezel -->
    <path
        android:pathData="M15,20h70a8,8 0 0 1 8,8v40a8,8 0 0 1 -8,8H15a8,8 0 0 1 -8,-8V28a8,8 0 0 1 8,-8z"
        android:strokeWidth="2">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="15"
                android:startY="20"
                android:endX="85"
                android:endY="76"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD043F3" />
                <item android:offset="1.0" android:color="#FF00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- TV Antennas -->
    <path
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M35,10 L45,20 M65,10 L55,20">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="35"
                android:startY="10"
                android:endX="65"
                android:endY="20"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD043F3" />
                <item android:offset="1.0" android:color="#FF00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- TV Stand -->
    <path
        android:pathData="M40,76 L36,86 L64,86 L60,76 Z"
        android:fillColor="#FF181824" />
    <path
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M30,86 L70,86">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="86"
                android:endX="70"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD043F3" />
                <item android:offset="1.0" android:color="#FF00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Innermost Screen Area with Back-plate -->
    <path
        android:pathData="M18,23h64a3,3 0 0 1 3,3v34a3,3 0 0 1 -3,3H18a3,3 0 0 1 -3,-3V26a3,3 0 0 1 3,-3z"
        android:fillColor="#FF0B0B14" />

    <!-- Play Symbol/Media Waves inside -->
    <path
        android:pathData="M42,34 L63,44 L42,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="42"
                android:startY="34"
                android:endX="63"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD043F3" />
                <item android:offset="1.0" android:color="#FF00E5FF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
